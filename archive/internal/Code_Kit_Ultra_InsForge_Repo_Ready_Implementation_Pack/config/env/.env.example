# Shared
NODE_ENV=development
LOG_LEVEL=debug

# InsForge
INSFORGE_PROJECT_ID=your_project_id
INSFORGE_API_URL=https://api.insforge.example
INSFORGE_JWKS_URL=https://api.insforge.example/.well-known/jwks.json
INSFORGE_DATABASE_URL=postgres://user:pass@host:5432/db
INSFORGE_STORAGE_BUCKET_RUN_ARTIFACTS=run-artifacts
INSFORGE_STORAGE_BUCKET_REPORTS=reports

# Control service
CONTROL_SERVICE_PORT=4000
CONTROL_SERVICE_BASE_URL=http://localhost:4000
CONTROL_SERVICE_SIGNING_KEY=replace_me
CONTROL_SERVICE_TOKEN_TTL_SECONDS=300

# Realtime
REALTIME_PROVIDER=insforge
REALTIME_CHANNEL_PREFIX=codekit

# Execution workers
EXECUTION_QUEUE_URL=memory://local
EXECUTION_WORKER_CONCURRENCY=4

# Legacy compatibility
ENABLE_LEGACY_API_KEYS=true
LEGACY_API_KEY_HEADER=x-api-key
