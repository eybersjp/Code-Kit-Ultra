{
  "name": "code-kit-ultra",
  "version": "0.9.0-phase9",
  "private": true,
  "type": "module",
  "description": "Code Kit Ultra Phase 9 - enterprise hardening with auth, policy, audit, metrics, and GitHub checks",
  "bin": {
    "code-kit": "./apps/cli/src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx apps/cli/src/index.ts",
    "ck": "tsx apps/cli/src/index.ts",
    "control-service": "tsx packages/control-service/src/server.ts",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx examples/smoke-test.ts",
    "test:execution": "tsx examples/execution-engine-test.ts",
    "test:github": "tsx examples/github-adapter-test.ts",
    "test:control-service": "tsx examples/control-service-test.ts",
    "test:enterprise": "tsx examples/enterprise-hardening-test.ts",
    "test:all": "tsx examples/smoke-test.ts && tsx examples/execution-engine-test.ts && tsx examples/github-adapter-test.ts && tsx examples/control-service-test.ts && tsx examples/enterprise-hardening-test.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
