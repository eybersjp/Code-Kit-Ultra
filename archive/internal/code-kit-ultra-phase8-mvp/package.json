{
  "name": "code-kit-ultra",
  "version": "0.8.0-phase8",
  "private": true,
  "type": "module",
  "description": "Code Kit Ultra Phase 8 - governed execution engine with resumable runs, retries, rollback, and IDE-native artifact schema",
  "bin": {
    "code-kit": "./apps/cli/src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx apps/cli/src/index.ts",
    "ck": "tsx apps/cli/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx examples/smoke-test.ts",
    "test:execution": "tsx examples/execution-engine-test.ts",
    "test:all": "tsx examples/smoke-test.ts && tsx examples/execution-engine-test.ts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
