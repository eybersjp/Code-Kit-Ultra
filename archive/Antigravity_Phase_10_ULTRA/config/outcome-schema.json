{
  "type": "object",
  "required": [
    "runId",
    "qualityScore",
    "retryCount",
    "durationMs",
    "verificationStatus"
  ],
  "properties": {
    "runId": {
      "type": "string"
    },
    "qualityScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "retryCount": {
      "type": "integer",
      "minimum": 0
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "failureTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verificationStatus": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "partial"
      ]
    },
    "operatorRating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "operatorComment": {
      "type": "string"
    }
  }
}
