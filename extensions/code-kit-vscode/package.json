{
  "name": "code-kit-vscode",
  "displayName": "Code Kit Ultra Control Plane",
  "description": "IDE-Native Control Plane for Governed Autonomous Engineering.",
  "version": "1.2.0",
  "publisher": "eybersjp",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Code Kit Ultra",
      "properties": {
        "codeKitUltra.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Control Service authentication"
        },
        "codeKitUltra.controlServiceUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "URL of the local Control Service"
        },
        "codeKitUltra.workspacePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Code Kit Ultra repository (used for auto-start)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "code-kit-ultra",
          "title": "Code Kit Ultra",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "code-kit-ultra": [
        {
          "id": "code-kit-overview",
          "name": "Overview"
        },
        {
          "id": "code-kit-runs",
          "name": "Runs"
        },
        {
          "id": "code-kit-approvals",
          "name": "Approvals"
        },
        {
          "id": "code-kit-alerts",
          "name": "Alerts"
        }
      ]
    },
    "commands": [
      {
        "command": "code-kit.openControlPanel",
        "title": "CK: Open Control Plane",
        "category": "Code Kit"
      },
      {
        "command": "code-kit.startControlService",
        "title": "CK: Start Control Service",
        "category": "Code Kit"
      },
      {
        "command": "code-kit.refresh",
        "title": "CK: Refresh Data",
        "icon": "$(refresh)"
      },
      {
        "command": "code-kit.approveBatch",
        "title": "CK: Approve Batch",
        "icon": "$(check)"
      },
      {
        "command": "code-kit.rejectBatch",
        "title": "CK: Reject Batch",
        "icon": "$(x)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "code-kit.approveBatch",
          "when": "view == code-kit-approvals",
          "group": "inline"
        },
        {
          "command": "code-kit.rejectBatch",
          "when": "view == code-kit-approvals",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsup src/extension.ts --external vscode --format cjs --no-shims",
    "watch": "tsup src/extension.ts --external vscode --format cjs --watch --no-shims",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "axios": "^1.7.7"
  }
}
