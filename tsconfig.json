{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["packages/shared/src/*"],
      "@audit/*": ["packages/audit/src/*"],
      "@orchestrator/*": ["packages/orchestrator/src/*"],
      "@governance/*": ["packages/governance/src/*"],
      "@memory/*": ["packages/memory/src/*"],
      "@core/*": ["packages/core/src/*"]
    }
  },
  "include": ["packages", "apps", "config", "examples"]
}
