{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["packages", "apps", "config", "examples"],
  "exclude": [
    "packages/cku/codekit/**",
    "**/*.test.ts",
    "apps/control-service/test/**"
  ]
}
